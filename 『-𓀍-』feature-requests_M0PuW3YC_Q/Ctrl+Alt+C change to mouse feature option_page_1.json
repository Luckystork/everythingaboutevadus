[{"id":"1413377918201233460","channel_id":"1409632768660476104","author":{"id":"1411567837633445969","username":"devil_hunter907","avatar":null,"discriminator":"0","public_flags":0,"flags":0,"banner":null,"accent_color":null,"global_name":"Devil_hunter","avatar_decoration_data":null,"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null},"content":"You need something like this. I recently connected with a person from pakistan who give exams which has secondary camera like TOEFl and Duolingo. He showed me how he would do it. There will be three cursors. During the exam, he will point hi own cursor on the answers and I need to take my cursor to the answer and click it. There will be another cursor following my main cursor which basically a delayed cursor (this will be shown to the proctor or being recorded). During long answer typing sections, he will show me answers on a transparent screen. I guess this screen is not detectable, just like the Evadus Invisible Overlay. This guys are really into this game from soo long. @bizarro12345  If by any chance, could you create such kind of feature where another person shows/operates only through cursor. The candidate appearing for the exam only has to follow that cursor and type and click answers, It would be a big game changer.","timestamp":"2025-09-05T04:19:14.991000+00:00","edited_timestamp":null,"tts":false,"mention_everyone":false,"mentions":[{"id":"707511200765968464","username":"bizarro12345","avatar":"10d86e1edf4cdef16401c63ed4d57410","discriminator":"0","public_flags":64,"flags":64,"banner":null,"accent_color":null,"global_name":"Bizarro","avatar_decoration_data":{"asset":"a_795f81ea071513ca4394a53e009792ac","sku_id":"1413650166774366279","expires_at":null},"collectibles":null,"display_name_styles":null,"banner_color":null,"clan":null,"primary_guild":null}],"attachments":[{"id":"1413377917836066877","filename":"File.mp4","size":15243545,"url":"https://cdn.discordapp.com/att